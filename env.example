# OpenAI Compatible LLM Configuration

# Base URL of the LLM API (e.g., https://api.openai.com/v1 or local deployment)
BASE_URL=https://api.openai.com/v1

# Model name to use (e.g., gpt-3.5-turbo, gpt-4)
MODEL=gpt-3.5-turbo

# API Key for authentication
API_KEY=your_api_key_here

# Optional: Temperature setting (0.0-2.0)
TEMPERATURE=0.7

# Optional: Maximum tokens for response
MAX_TOKENS=1000